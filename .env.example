# Copy to `.env` and fill in. Only EXPO_PUBLIC_* vars are exposed to the client.
# NEVER put secrets (API keys, DB creds) here — this bundle ships to devices.

EXPO_PUBLIC_API_URL=https://www.gripontrip.com/api
EXPO_PUBLIC_WEB_URL=https://www.gripontrip.com
EXPO_PUBLIC_ENV=development

# Supabase (auth + booking/review writes — same project the web uses).
# The anon key is public/client-safe (role: anon) and guarded by row-level
# security — it is designed to ship in client bundles, so it's safe to keep here.
EXPO_PUBLIC_SUPABASE_URL=https://ivkorsriknpkrdnmmgwg.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml2a29yc3Jpa25wa3Jkbm1tZ3dnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3MzY4NTk5NTUsImV4cCI6MjA1MjQzNTk1NX0.NQQr9a97XmCSBN3JXoqboKbFJ2tD10mr_cv66DEjHGU

# Stripe — publishable key only. It is client-safe (it can only tokenize cards /
# create PaymentIntents, never charge or read data), so it's fine to ship in the
# bundle. Get it from https://dashboard.stripe.com/apikeys (pk_test_… for dev).
# The SECRET key (sk_…) is NEVER put here — it lives only as a Supabase Edge
# Function secret. See docs/PAYMENTS.md.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
